# ── ClearChart Environment ───────────────────────────────
# Copy to .env and fill in. NEVER commit .env.
#   cp backend/.env.example .env        (compose reads .env at the repo root)

# ── REQUIRED ──────────────────────────────────────────────
# Get one at https://console.anthropic.com/ . Without it the app still runs
# but returns a deterministic "rule-only" report (no LLM summary).
ANTHROPIC_API_KEY=sk-ant-...

# ── LLM ───────────────────────────────────────────────────
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=3000
LLM_TEMPERATURE=0.2

# ── LLM FALLBACK (optional) ───────────────────────────────
# When the primary provider is rate-limited or down, requests automatically
# retry on OpenRouter (same Llama family). Get a key at https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# ── EMBEDDINGS ────────────────────────────────────────────
# local = keyless sentence-transformers vectors (default). none = BM25 only.
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── DATABASE ──────────────────────────────────────────────
# docker-compose sets this to the postgres service automatically.
# Local without Docker: leave blank to use SQLite (sqlite+aiosqlite:///./clearchart.db)
DATABASE_URL=postgresql+asyncpg://clearchart:clearchart@db:5432/clearchart

# ── REDIS / QUEUE ─────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── STORAGE ───────────────────────────────────────────────
UPLOAD_DIR=/data/uploads

# ── MISC ──────────────────────────────────────────────────
CORS_ORIGINS=*
LOG_LEVEL=INFO
